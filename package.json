{
  "name": "zeta-vscode",
  "displayName": "Zeta Language Support",
  "description": "Syntax highlighting, snippets, and language support for the Zeta programming language",
  "version": "0.1.0",
  "publisher": "murphsicles",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "zeta",
      "aliases": ["Zeta", "zeta"],
      "extensions": [".z", ".zeta"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "./icons/zeta-icon-light.svg",
        "dark": "./icons/zeta-icon-dark.svg"
      }
    }],
    "grammars": [{
      "language": "zeta",
      "scopeName": "source.zeta",
      "path": "./syntaxes/zeta.tmLanguage.json"
    }],
    "snippets": [{
      "language": "zeta",
      "path": "./snippets/zeta.json"
    }]
  }
}
